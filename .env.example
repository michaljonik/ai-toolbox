# API key used both as X-API-Key header value and as the OAuth bearer token.
# Leave empty to disable authentication entirely.
API_KEY=

# OAuth client credentials (client_credentials grant).
# Set both to enable the /oauth/token endpoint.
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=

# Public base URL of this server — used in OAuth metadata discovery.
SERVER_BASE_URL=http://localhost:8000
